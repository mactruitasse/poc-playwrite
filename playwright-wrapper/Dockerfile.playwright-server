FROM mcr.microsoft.com/playwright:v1.49.0-noble

WORKDIR /app

# Installation des dépendances
COPY package.json ./
RUN npm install @modelcontextprotocol/sdk express playwright

# Copie du serveur corrigé
COPY server.cjs ./

# Port MCP
EXPOSE 8933

CMD ["bash", "-lc", "ulimit -n 65535 || true; node /app/server.cjs"]
