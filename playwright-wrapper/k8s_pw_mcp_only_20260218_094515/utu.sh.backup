#!/usr/bin/env bash
set -euo pipefail

### =========================
### Config
### =========================
NS="n8n-prod"
PW_SVC="pw-cfa20bbf48b4d847"
PW_PORT="8933"
CURL_IMAGE="curlimages/curl:8.6.0"
MAX_TIME="15"
OUT_DIR="./k8s_pw_mcp_only_$(date +%Y%m%d_%H%M%S)"
### =========================

mkdir -p "${OUT_DIR}"

echo "==> Backup de l'ancien utu.sh (si présent)"
if [[ -f "./utu.sh" ]]; then
  cp -a ./utu.sh "${OUT_DIR}/utu.sh.backup"
fi

echo "==> Écriture d'un script utu_mcp.sh (MCP-only)"
cat > "${OUT_DIR}/utu_mcp.sh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

NS="${NS:-n8n-prod}"
PW_SVC="${PW_SVC:-pw-cfa20bbf48b4d847}"
PW_PORT="${PW_PORT:-8933}"
CURL_IMAGE="${CURL_IMAGE:-curlimages/curl:8.6.0}"
MAX_TIME="${MAX_TIME:-15}"

kubectl -n "${NS}" get svc "${PW_SVC}" >/dev/null

kubectl -n "${NS}" run "curlmcp-$(date +%s)" --rm -i --restart=Never --image="${CURL_IMAGE}" -- \
  sh -lc "
    set -eu
    base='http://${PW_SVC}:${PW_PORT}'

    echo '--- A) GET /mcp (juste pour voir le code) ---'
    curl -sv --max-time ${MAX_TIME} \"\$base/mcp\" 2>&1 | tail -n 120 || true

    echo
    echo '--- B) POST /mcp JSON-RPC __ping__ ---'
    curl -sv --max-time ${MAX_TIME} \
      -H 'Content-Type: application/json' \
      -H 'Accept: application/json' \
      -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"__ping__\",\"params\":{}}' \
      \"\$base/mcp\" 2>&1 | tail -n 200 || true
  "
EOF

# Inject config into heredoc script via env (no templating inside EOF)
export NS PW_SVC PW_PORT CURL_IMAGE MAX_TIME

chmod +x "${OUT_DIR}/utu_mcp.sh"

echo "==> Exécution: ${OUT_DIR}/utu_mcp.sh"
set +e
"${OUT_DIR}/utu_mcp.sh" 2>&1 | tee "${OUT_DIR}/run.log"
rc=${PIPESTATUS[0]}
set -e

echo
echo "==> Vérification: la sortie contient-elle une requête /mcp ?"
if grep -qE '^> (GET|POST) /mcp ' "${OUT_DIR}/run.log"; then
  echo "OK: /mcp a bien été testé."
else
  echo "ERREUR: aucune requête /mcp détectée dans la sortie."
  echo "Voici les 40 dernières lignes pour contexte :"
  tail -n 40 "${OUT_DIR}/run.log"
  exit 1
fi

exit "${rc}"
