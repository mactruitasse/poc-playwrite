+async def _ensure_mcp_initialized(si: SessionInfo) -> None:
+    """
+    Initialize MCP session against the upstream Playwright MCP server and cache mcp-session-id.
+    Required because upstream returns:
+      - 406 unless Accept includes both application/json and text/event-stream
+      - 'Server not initialized' unless mcp-session-id is provided after initialize
+    """
+    if si.mcp_session_id:
+        return
+    lock = MCP_INIT_LOCKS.setdefault(si.session_id, asyncio.Lock())
+    async with lock:
+        if si.mcp_session_id:
+            return
+        if not si.target_url:
+            raise HTTPException(status_code=404, detail="Unknown session")
+
+        upstream = f"{si.target_url.rstrip('/')}/mcp"
+        headers = {
+            "content-type": "application/json",
+            "accept": "application/json, text/event-stream",
+        }
+        payload = {
+            "jsonrpc": "2.0",
+            "id": 1,
+            "method": "initialize",
+            "params": {
