+                "clientInfo": {"name": "playwright-wrapper", "version": app.version},
+                "capabilities": {},
+            },
+        }
+
+        timeout = _httpx_timeouts(settings.http_default_read_timeout_seconds)
+        async with httpx.AsyncClient(timeout=timeout) as client_http:
